# Copy this file to .env and fill in real values.
# NEVER commit .env to git.

# Claude API (https://console.anthropic.com)
ANTHROPIC_API_KEY=sk-ant-...

# GitHub personal access token with repo + issues scopes
# (https://github.com/settings/tokens)
GITHUB_TOKEN=ghp_...

# The repo Helmsmen monitors, in owner/repo format
GITHUB_REPO=your-org/your-repo

# Webhook shared secret (set the same string in GitHub -> Settings -> Webhooks)
GITHUB_WEBHOOK_SECRET=change-me-to-a-long-random-string

# Slack bot token with chat:write (+ chat:write.public for public channels)
# (https://api.slack.com/apps -> OAuth & Permissions -> Bot Token)
SLACK_BOT_TOKEN=xoxb-...
SLACK_CHANNEL=#devops-alerts

# Optional: Tavily for CVE web search (https://tavily.com)
TAVILY_API_KEY=tvly-...

# Tuning
STALE_PR_DAYS=7
SCHEDULE_HOURS=1
PORT=5000
